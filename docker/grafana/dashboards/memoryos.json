{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "MemoryOS Kernel — request latency, memory hit-rate, extraction throughput, LTM archival",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
          "expr": "sum by (path) (rate(memoryos_requests_total[2m]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Latency — p50 / p95 (seconds)",
      "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
          "expr": "histogram_quantile(0.50, sum by (path, le) (rate(memoryos_request_duration_seconds_bucket[2m])))",
          "legendFormat": "p50 {{path}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
          "expr": "histogram_quantile(0.95, sum by (path, le) (rate(memoryos_request_duration_seconds_bucket[2m])))",
          "legendFormat": "p95 {{path}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 5, "showPoints": "never"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 0.25}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Memory Injection Hit Rate",
      "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
          "expr": "100 * sum(rate(memoryos_injection_total{result=\"hit\"}[10m])) / (sum(rate(memoryos_injection_total[10m])) + 1e-9)",
          "legendFormat": "Hit Rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "yellow", "value": 40},
              {"color": "green",  "value": 70}
            ]
          },
          "mappings": [],
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Memories Injected / Request",
      "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
          "expr": "rate(memoryos_injected_count_sum[10m]) / (rate(memoryos_injected_count_count[10m]) + 1e-9)",
          "legendFormat": "avg",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null}
            ]
          }
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area"}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "MMU Extraction Rate (extractions/s)",
      "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
          "expr": "sum by (status) (rate(memoryos_extraction_total[2m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "showPoints": "never"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "error"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          },
          {
            "matcher": {"id": "byName", "options": "ok"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]
          }
        ]
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Vector Search Latency — p50 / p95 (ms)",
      "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
          "expr": "1000 * histogram_quantile(0.50, rate(memoryos_vector_search_duration_seconds_bucket[2m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
          "expr": "1000 * histogram_quantile(0.95, rate(memoryos_vector_search_duration_seconds_bucket[2m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 8, "showPoints": "never"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "yellow", "value": 20},
              {"color": "red",    "value": 50}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Extraction LLM Latency — p50 / p95 (seconds)",
      "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
          "expr": "histogram_quantile(0.50, rate(memoryos_extraction_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
          "expr": "histogram_quantile(0.95, rate(memoryos_extraction_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 8, "showPoints": "never"}
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "LTM Archival Cycles (total)",
      "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
          "expr": "sum(memoryos_archival_total)",
          "legendFormat": "total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]}
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none"}
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Memories Compacted to L3 (total)",
      "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 24},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "memoryos-prometheus"},
          "expr": "sum(memoryos_archival_compacted_sum)",
          "legendFormat": "compacted",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "orange", "value": null}]}
        },
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none"}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["memoryos", "aeon-iq"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "MemoryOS Kernel",
  "uid": "memoryos-kernel-001",
  "version": 2
}
