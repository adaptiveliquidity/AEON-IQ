# ── Required ─────────────────────────────────────────────────────────────────

# Your OpenAI (or compatible) API key
# Used for: embedding generation + MMU extraction (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# ── Optional ──────────────────────────────────────────────────────────────────

# Target LLM provider base URL (default: OpenAI)
# Switch to Anthropic, Ollama, Together, etc. by changing this:
#   Anthropic:   https://api.anthropic.com  (needs an adapter)
#   Local Ollama: http://host.docker.internal:11434
UPSTREAM_BASE_URL=https://api.openai.com

# Cheap model used to extract facts from conversations (default: gpt-4o-mini)
EXTRACTOR_MODEL=gpt-4o-mini

# Embedding model + dimension (default: text-embedding-3-small at 1536 dims)
# To use bge-small-en (384 dims), also change vector(1536) in the migration.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Postgres (auto-configured by docker-compose; only needed for local dev)
DATABASE_URL=postgresql://memoryos:memoryos_secret@localhost:5432/memoryos
