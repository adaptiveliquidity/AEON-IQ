# Core
DATABASE_URL=postgresql://memoryos:memoryos_secret@localhost:5432/memoryos
PORT=8080
UPSTREAM_BASE_URL=https://api.openai.com
UPSTREAM_PROVIDER=openai

# Database pool
DB_MAX_CONNECTIONS=20
DB_ACQUIRE_TIMEOUT_SECS=5
DB_IDLE_TIMEOUT_SECS=300

# Keys and models
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_BASE_URL=https://api.openai.com
EXTRACTOR_MODEL=gpt-4o-mini
EXTRACTOR_BASE_URL=https://api.openai.com

# Retrieval tuning
RETRIEVAL_THRESHOLD=0.80
MEMORY_DECAY_RATE=0.0
IMPORTANCE_BOOST_FACTOR=0.0
IMPORTANCE_REFRESH_BOOST=0.05
GRAPH_RETRIEVAL_ENABLED=false
RETRIEVAL_LOG_QUERY_TEXT=false

# Data integrity
DEDUP_THRESHOLD=0.05
CONFLICT_DETECTION_ENABLED=false

# Management API security
MANAGEMENT_API_KEY=
ALLOW_UNAUTH_MANAGEMENT=false

# Request limits
MAX_BODY_BYTES=10485760

# Archival
# Each compaction cycle produces compressed L3 facts AND a 2-3 sentence
# narrative L3 memory (memory_type='narrative') tagged with the same
# archival_batch_id. Narrative work is best-effort and only happens on this
# background path — the retrieval hot-path is never blocked.
ARCHIVAL_INTERVAL_HOURS=24
ARCHIVAL_MIN_AGE_DAYS=7
ARCHIVAL_MIN_MEMORIES=10

# Proxy rate limiting
RATE_LIMIT_RPM=0
RATE_LIMIT_BURST=20

# Adaptive systems
AMP_ENABLED=false
RMK_ENABLED=false
